# Required: your iCloud login.
# Generate an app-specific password at:
#   https://account.apple.com → Sign-In and Security → App-Specific Passwords
ICLOUD_EMAIL=yourname@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: Mail / Calendar / Contacts endpoints. Defaults below match iCloud.
# Override only if you're proxying or testing against a different DAV server.
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
# CALDAV_URL=https://caldav.icloud.com    # Calendar + Reminders (VTODO)
# CARDDAV_URL=https://contacts.icloud.com # Contacts

# Optional: default IANA timezone for date/time outputs when a tool doesn't
# specify one. Falls back to system timezone if unset.
# DEFAULT_TIMEZONE=Australia/Melbourne

# Required for Vercel deployment (protects your endpoint on the public internet).
# Not needed for local stdio use with Claude Desktop.
AUTH_TOKEN=some-random-secret-token
